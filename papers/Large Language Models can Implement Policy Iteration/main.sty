\NewDocumentCommand
\Q{se{_^}ooo}{%
    \IfBooleanTF{#1}{\QFunc*}{\QFunc}
    _{#2}
    ^{#3}
    \IfValueT{#4}{
        \Parens( #4,
        \IfValueTF{#5}{#5}{\cdot}
        \IfValueT{#6}{, #6}
        )
    }
}

